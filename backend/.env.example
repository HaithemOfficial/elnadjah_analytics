PORT=4000
CORS_ORIGIN=http://localhost:5173
AUTH_TOKEN_TTL_HOURS=24
ADMIN_EMAIL=admin@elnadjah.com
ADMIN_PASSWORD=Admin@123456
FOUNDER1_EMAIL=founder1@example.com
FOUNDER1_PASSWORD=change_me
FOUNDER2_EMAIL=founder2@example.com
FOUNDER2_PASSWORD=change_me
MANAGER_EMAIL=manager@example.com
MANAGER_PASSWORD=change_me
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_RANGE=A:Z
GOOGLE_SHEET_GID=867516880
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Daily summary email notifications (optional)
DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_CRON=0 9 * * *
DAILY_SUMMARY_TIMEZONE=Africa/Algiers
DAILY_SUMMARY_RECIPIENTS=haithemofficial@gmail.com

# ── Friday weekly pack (WEEKLY_SUMMARY_ENABLED=true triggers all three below) ──
# 1. Weekly sheet summary  →  sent to WEEKLY_SUMMARY_RECIPIENTS (manager + founders)
#    Includes: total leads, assigned, interested, not contacted, team leaderboard, destinations leaderboard
# 2. Per-agent performance → sent to WEEKLY_AGENT_MANAGER_RECIPIENTS + each agent's own email
#    Includes: contacted, interested, interested rate, active days
# 3. Red alert emails      → sent to AGENT_ALERT_MANAGER_RECIPIENTS + AGENT_ALERT_FOUNDERS_RECIPIENTS + each flagged agent
#    Agent is asked to reply with an explanation
# Week = Saturday → Friday (Algeria)
WEEKLY_SUMMARY_ENABLED=false
WEEKLY_SUMMARY_CRON=0 11 * * 5
WEEKLY_SUMMARY_TIMEZONE=Africa/Algiers
# Add both manager and founders here (comma-separated)
WEEKLY_SUMMARY_RECIPIENTS=manager@example.com,founder1@example.com,founder2@example.com

# Weekly agent performance report — manager + the agent themselves
WEEKLY_AGENT_MANAGER_RECIPIENTS=manager@example.com

# Red alert emails — checked daily; also included in Friday weekly pack
# Triggers when an agent: is inactive 2+ days in a row, works <4 days in the week,
# contacts <50 leads in the week, or has <10% interested rate in the week.
AGENT_ALERTS_ENABLED=false
AGENT_ALERTS_CRON=0 10 * * *
AGENT_ALERTS_TIMEZONE=Africa/Algiers
AGENT_ALERT_MANAGER_RECIPIENTS=manager@example.com
AGENT_ALERT_FOUNDERS_RECIPIENTS=founder1@example.com,founder2@example.com

# Agent email mapping (name:email, comma-separated)
AGENT_EMAIL_MAP=Kamilia:kamilia@example.com,Telissa:telissa@example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=analytics.elnadjah
SMTP_PASS=your_smtp_password
SMTP_FROM="ElNadjah Dashboard <no-reply@elnadjah.com>"

